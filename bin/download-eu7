#!/usr/bin/env python3
"""Download gold-standard EU7 training data from Ensembl/GENCODE.

Downloads protein-coding and lncRNA transcript FASTAs for the 7 core
Eukaryota species used in Singh & Roy 2022 benchmark. All URLs are
versioned for reproducibility.

Output: data/eu7/<species>/{coding.fa, noncoding.fa, manifest.json}

Usage:
    bin/download-eu7                    # download all 7 species
    bin/download-eu7 --species human    # download one species
    bin/download-eu7 --check            # verify checksums only
"""

from __future__ import annotations

import argparse
import gzip
import hashlib
import json
import shutil
import ssl
import sys
import urllib.request
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
OUTPUT_DIR = PROJECT_ROOT / "data" / "eu7"

# ── Versioned source URLs ─────────────────────────────────────────
# GENCODE for human/mouse (gold standard, experimentally validated)
# Ensembl for other species (curated genome annotations)
# All transcript-level FASTA files, not genome assemblies.

ENSEMBL_RELEASE = 113  # 2024-10, latest stable at time of writing

EU7_SOURCES: dict[str, dict] = {
