#!/usr/bin/env bash
#
# Run feature extraction on all benchmark datasets (single node).
# For distributed (2-node) extraction, use bin/extract-all-features instead.
#
# Usage:
#   bash bin/run-all-features                    # CPU + CaLM + Pfam
#   bash bin/run-all-features --skip-gpu         # CPU only
#
# Designed to run INSIDE the gt5 container on DGX Spark.

set -euo pipefail

cd /workspace/Code/ProteinQC

PFAM_FLAG=""
PFAM_DB="models/pfam/Pfam-A.hmm"
if [ -f "$PFAM_DB" ]; then
    PFAM_FLAG="--pfam --pfam-db $PFAM_DB"
    echo "Pfam database found: $PFAM_DB"
else
    echo "WARNING: Pfam database not found, skipping Pfam"
fi

echo "========================================"
echo "Feature extraction: all benchmark datasets"
echo "Output: data/features/"
echo "========================================"

python -m proteinqc.cli.extract_features \
    --benchmark-root data/benchmark \
    --output-dir data/features \
    $PFAM_FLAG \
    "$@"

echo ""
echo "========================================"
echo "ALL DONE"
echo "Output files:"
ls -lh data/features/*.parquet 2>/dev/null
echo "========================================"
